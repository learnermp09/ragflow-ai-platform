# Normalize all text files to LF in the repository
* text=auto

# Python source
*.py text eol=lf

# Markdown
*.md text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# TOML
*.toml text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# PowerShell
*.ps1 text eol=crlf